<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Privacy manifest for OpenGlasses.

  Required by Apple for App Store submission alongside the MFi / ExternalAccessory
  integration (the Wearables DAT SDK). Public App Store distribution is not yet
  supported by Meta, so this manifest is forward-looking groundwork.

  NSPrivacyAccessedAPITypes below cover the required-reason APIs actually used in
  this target's source:
    - UserDefaults (standard suite, ~22 files)  -> CA92.1
    - File timestamps (HIPAAComplianceService,
      creationDateKey on the app's own container) -> DDA9.1
    - Disk space (DeviceInfoTool, .systemFreeSize) -> E174.1

  NSPrivacyCollectedDataTypes reflect a source audit of what actually leaves the
  device. OpenGlasses has no developer-operated backend or user account: every
  transmission is user-directed app functionality sent under the user's own API
  keys to third-party providers (Anthropic / OpenAI / Gemini / Groq / OpenRouter
  / etc. for LLM + vision, ElevenLabs for TTS, Perplexity / DuckDuckGo for
  search, open-meteo / adsb.fi for weather + flights, RTMP / WebRTC for live
  streaming). There is no analytics, crash-reporting, or advertising SDK, and no
  cross-app/-developer tracking — so every type below is Linked=false,
  Tracking=false, purpose = App Functionality.

  Notes for whoever finalizes submission:
    - Health & Fitness data (HealthKit, via FitnessCoachingTool) is surfaced into
      LLM tool results, i.e. transmitted to a third party. Apple forbids using
      HealthKit data for advertising/data-mining and requires user consent for
      third-party sharing — keep purpose strictly AppFunctionality and ensure the
      in-app consent copy covers LLM transmission.
    - Contacts (ContactsTool returns name/phone/email) and Precise Location
      (weather/flight/maps tools) likewise enter LLM context.
    - "Linked=false" assumes no account system is added later. If OpenGlasses ever
      gains sign-in or a first-party backend, revisit every Linked flag.
-->
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<!-- Voice/transcripts to LLMs, mic audio to Gemini Live / OpenAI Realtime, text to ElevenLabs TTS -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeAudioData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- Glasses camera frames sent to LLM vision; live video via RTMP / WebRTC -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePhotosorVideos</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- Prompts, notes, meeting summaries, message drafts sent to LLM providers -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeOtherUserContent</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- lat/lon sent to weather (open-meteo), flights (adsb.fi), maps, and into LLM context -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePreciseLocation</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- HealthKit reads (FitnessCoachingTool) surfaced into LLM tool results -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeHealth</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeFitness</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- ContactsTool returns name/phone/email of looked-up contacts to the LLM -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeContacts</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- Web search queries sent to Perplexity / DuckDuckGo -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeSearchHistory</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
	</array>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>DDA9.1</string>
			</array>
		</dict>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryDiskSpace</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>E174.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
