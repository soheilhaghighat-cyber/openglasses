    "Enterprise customers receive a code with their order. Codes are signed and validated on-device — no network required." : {
      "comment" : "A description of how enterprise customers can purchase Field Assist.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enterprise-Kunden erhalten einen Code mit ihrer Bestellung. Codes werden signiert und auf dem Gerät validiert – keine Netzwerkverbindung erforderlich."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los clientes empresariales reciben un código con su pedido. Los códigos se firman y se validan en el dispositivo: no se requiere conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les clients entreprise reçoivent un code avec leur commande. Les codes sont signés et validés sur l'appareil — aucune connexion requise."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "エンタープライズのお客様は、ご注文時にコードを受け取ります。コードは署名され、デバイス上で検証されます — ネットワークは不要です。"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klienci korporacyjni otrzymują kod wraz z zamówieniem. Kody są podpisywane i weryfikowane na urządzeniu — bez połączenia z siecią."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "企业客户会随订单收到一个代码。代码经过签名并在设备上验证——无需联网。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
