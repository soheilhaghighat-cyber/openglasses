    },
    "Browse the reference content read-only. Unlocking lets you edit it, run grounded sessions, and export." : {
      "comment" : "A description of the benefits of unlocking Field Assist.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durchsuche die Referenzinhalte schreibgeschützt. Nach dem Freischalten kannst du sie bearbeiten, fundierte Sitzungen ausführen und exportieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Explora el contenido de referencia en modo de solo lectura. Al desbloquearlo podrás editarlo, ejecutar sesiones fundamentadas y exportarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parcourez le contenu de référence en lecture seule. Le déverrouillage vous permet de le modifier, de lancer des sessions documentées et de l'exporter."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "参照コンテンツを読み取り専用で閲覧できます。ロックを解除すると、編集、グラウンディングされたセッションの実行、書き出しが可能になります。"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeglądaj treści referencyjne tylko do odczytu. Odblokowanie pozwala je edytować, uruchamiać sesje oparte na danych i eksportować."
          }
        },
        "zh-Hans" : {
