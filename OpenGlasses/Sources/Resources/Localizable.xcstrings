    "%lld skill%@ will be added **disabled**. Each injects its prompt into the AI's context, so review and enable them individually before use." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld Skill%2$@ werden **deaktiviert** hinzugefügt. Jeder fügt seinen Prompt in den Kontext der KI ein – prüfe sie und aktiviere sie einzeln vor der Verwendung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld skill%2$@ will be added **disabled**. Each injects its prompt into the AI's context, so review and enable them individually before use."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se añadirán %1$lld habilidades **desactivadas**. Cada una inserta su prompt en el contexto de la IA, así que revísalas y actívalas individualmente antes de usarlas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld compétence%2$@ seront ajoutées **désactivées**. Chacune insère son prompt dans le contexte de l'IA ; passez-les en revue et activez-les individuellement avant utilisation."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld 件のスキルが**無効**の状態で追加されます。それぞれが AI のコンテキストにプロンプトを挿入するため、使用する前に個別に確認して有効にしてください。"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zostanie dodanych %1$lld umiejętności w stanie **wyłączonym**. Każda wstrzykuje swój prompt do kontekstu SI, więc przejrzyj je i włącz pojedynczo przed użyciem."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将添加 %1$lld 个技能，且默认**禁用**。每个技能都会将其提示词注入 AI 的上下文，因此请在使用前逐个检查并启用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將新增 %1$lld 個技能，且預設**停用**。每個技能都會將其提示詞注入 AI 的上下文，因此請在使用前逐個檢查並啟用。"
          }
        }
      }
