name: Build iOS App

on:
  workflow_dispatch: 

jobs:
  build:
    runs-on: macos-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install xcodegen
        run: brew install xcodegen

      - name: Generate Xcode Project
        run: ./Scripts/generate-xcodeproj.sh

      - name: Build the app (Unsigned)
        run: |
          xcodebuild clean build \
            -project OpenGlasses.xcodeproj \
            -scheme OpenGlasses \
            -sdk iphoneos \
            -configuration Release \
            CODE_SIGN_IDENTITY="" \
            CODE_SIGNING_REQUIRED=NO \
            CODE_SIGNING_ALLOWED=NO \
            DSTROOT=$PWD/build \
            OBJROOT=$PWD/build \
            SYMROOT=$PWD/build

      - name: Package into IPA
        run: |
          mkdir -p Payload
          mv build/Release-iphoneos/OpenGlasses.app Payload/
          zip -r OpenGlasses.ipa Payload

      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: OpenGlasses-IPA
          path: OpenGlasses.ipa
